<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Laptop-side LaunchAgent: sync ~/.claude/projects to the Studio every 5 min.

  Install (on the MBP):
    cp deploy/com.david.gloss-sync.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.david.gloss-sync.plist

  Requires SSH key auth to david@100.109.110.36 (already configured per infra.md).
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.david.gloss-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/david/.local/bin/gloss-sync-to-studio.sh</string>
  </array>

  <key>StartInterval</key>
  <integer>300</integer>
  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/david/Library/Logs/gloss-sync.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/david/Library/Logs/gloss-sync.err.log</string>
</dict>
</plist>
